rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function adminDoc() {
      return /databases/$(database)/documents/adminUsers/$(request.auth.uid);
    }

    function isAdmin() {
      return signedIn()
        && exists(adminDoc())
        && get(adminDoc()).data.active != false;
    }

    match /adminUsers/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    match /gallery/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /sponsors/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /socialWork/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /news/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /awards/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
